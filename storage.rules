rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isEditor() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if true;  // Anyone can read user profiles
      allow create: if isOwner(userId);  // Users can create their own profile
      allow update: if isOwner(userId) || isAdmin();  // Users or admins can update
      allow delete: if false;  // No one can delete users
    }
    
    // Posts collection
    match /posts/{postId} {
      allow read: if true;  // Anyone can read posts
      allow create: if isEditor();  // Only editors can create
      allow update: if isEditor() && 
                     (isAdmin() || resource.data.authorId == request.auth.uid);  // Editors can update their own, admins can update any
      allow delete: if isAdmin();  // Only admins can delete
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read: if true;  // Anyone can read comments
      allow create: if isAuthenticated();  // Logged in users can comment
      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;  // Users can edit their own comments
      allow delete: if isAuthenticated() && 
                     (resource.data.authorId == request.auth.uid || isAdmin());  // Users or admins can delete
    }
    
    // Donations collection
    match /donations/{donationId} {
      allow read: if isAdmin();  // Only admins can see donations
      allow create: if true;  // Anyone can donate (even anonymous)
      allow update: if false;  // No editing donations
      allow delete: if false;  // No deleting donations
    }
    
    // Contacts collection
    match /contacts/{contactId} {
      allow read: if isAdmin();  // Only admins can see contact submissions
      allow create: if true;  // Anyone can submit contact form
      allow update: if false;
      allow delete: if false;
    }
    
    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;  // Anyone can read categories
      allow create: if isAdmin();  // Only admins can create categories
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
